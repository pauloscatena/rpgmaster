DISCORD_TOKEN=
DISCORD_CLIENT_ID=
# Opcional: defina para registrar os comandos apenas neste servidor (propaga na hora, ótimo para desenvolvimento).
# Deixe em branco para registrar globalmente (pode levar até ~1h para aparecer).
DISCORD_GUILD_ID=
DATABASE_URL=postgres://postgres:rpgmaster@localhost:55432/rpgmaster
ANTHROPIC_API_KEY=
LLM_PROVIDER=claude
# Dev (Ollama no host): http://localhost:11434
# Prod (serviço ollama no docker-compose.prod.yml): http://ollama:11434
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:7b
# Timeout por chamada ao LLM (ms). Em Ollama CPU-only, tool loops podem passar de 30s.
# LLM_REQUEST_TIMEOUT_MS=90000
# Limite de tokens gerados por chamada Ollama (acelera respostas longas demais).
# OLLAMA_NUM_PREDICT=512
# Opcional: necessário apenas para referenciar documentos via Google Docs em /criar-campanha.
# JSON da chave da conta de serviço do Google, codificado em base64.
# Veja docs/superpowers/specs/2026-07-07-google-docs-campaign-reference-design.md para o setup completo.
GOOGLE_SERVICE_ACCOUNT_KEY=

# --- Produção (docker-compose.prod.yml) ---
# Senha forte, de preferência só alfanumérica (evita quebrar a URL do Postgres).
# POSTGRES_PASSWORD é obrigatório em produção; o Compose monta DATABASE_URL para o serviço db.
POSTGRES_USER=rpgmaster
POSTGRES_PASSWORD=
POSTGRES_DB=rpgmaster
# Com LLM_PROVIDER=ollama em produção:
# LLM_PROVIDER=ollama
# OLLAMA_BASE_URL=http://ollama:11434
# OLLAMA_MODEL=qwen2.5:7b
# (já é Q4_K_M por padrão). Alternativa mais rápida / menos qualidade: qwen2.5:3b
#
# Env do serviço ollama (CPU-only) — defaults no docker-compose.prod.yml:
# OLLAMA_NUM_THREAD=4
# OLLAMA_KEEP_ALIVE=-1
# OLLAMA_NUM_PARALLEL=1
# OLLAMA_CONTEXT_LENGTH=4096
# O bot também envia num_ctx/num_thread/num_predict por request:
# OLLAMA_NUM_CTX=4096
# OLLAMA_NUM_THREAD=4
# OLLAMA_NUM_PREDICT=512

